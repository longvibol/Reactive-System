      "item": [
        {
          "name": "01 Register Phone",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 201 or 200\", function () { pm.expect([200,201]).to.include(pm.response.code); });",
                  "const json = pm.response.json();",
                  "if (json.userAccountId) { pm.collectionVariables.set(\"userAccountId\", json.userAccountId); }",
                  "if (json.registrationStatus) { pm.collectionVariables.set(\"registrationStatus\", json.registrationStatus); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"countryCode\": \"{{countryCode}}\",\n  \"phoneNumber\": \"{{phoneNumber}}\",\n  \"userType\": \"{{userType}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
